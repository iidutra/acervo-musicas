# ==============================================================================
# Local Development (docker-compose)
# ==============================================================================
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local)
DB_NAME=acervo_liturgico
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Media
MEDIA_ROOT=media

# ==============================================================================
# Production / Railway
# Variáveis a configurar no Railway Dashboard:
# ==============================================================================
# DJANGO_SETTINGS_MODULE=config.settings.prod
# SECRET_KEY=<gerar-chave-secreta-forte>
# ALLOWED_HOSTS=<seu-app>.up.railway.app
# DATABASE_URL=<fornecido-automaticamente-pelo-railway>
# CSRF_TRUSTED_ORIGINS=https://<seu-app>.up.railway.app
# SECURE_SSL_REDIRECT=True
